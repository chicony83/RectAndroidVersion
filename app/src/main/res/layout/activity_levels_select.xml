<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/menu_background"
    tools:context=".SelectLevelsActivity">

    <TextView
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:contentDescription="@string/back"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:onClick="onClickBack"
        android:text="‹"
        android:textColor="@color/menu_text_primary"
        android:textSize="38sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/levelTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:fontFamily="sans-serif-light"
        android:text="@string/select_level_title"
        android:textColor="@color/menu_text_primary"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backButton" />

    <TextView
        android:id="@+id/levelSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="32dp"
        android:fontFamily="sans-serif"
        android:text="@string/select_level_subtitle"
        android:textColor="@color/menu_text_secondary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/levelTitle" />

    <ScrollView
        android:id="@+id/levelScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/levelSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:onClick="onClickSelectForKidsLevel"
                app:levelAccent="@color/level_sage"
                app:levelSubtitle="@string/for_kids_level_description"
                app:levelTitle="@string/for_kids_level" />

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:onClick="onClickSelectVeryEasyLevel"
                app:levelAccent="@color/level_sage"
                app:levelSubtitle="@string/very_easy_level_description"
                app:levelTitle="@string/very_easy_level" />

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:onClick="onClickSelectEasyLevel"
                app:levelAccent="@color/level_blue"
                app:levelSubtitle="@string/easy_level_description"
                app:levelTitle="@string/easy_level" />

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:onClick="onClickSelectMediumLevel"
                app:levelAccent="@color/level_blue"
                app:levelSubtitle="@string/medium_level_description"
                app:levelTitle="@string/medium_level" />

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:onClick="onClickSelectHardLevel"
                app:levelAccent="@color/level_sand"
                app:levelSubtitle="@string/hard_level_description"
                app:levelTitle="@string/hard_level" />

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:onClick="onClickSelectVeryHardLevel"
                app:levelAccent="@color/level_terracotta"
                app:levelSubtitle="@string/very_hard_level_description"
                app:levelTitle="@string/very_hard_level" />

            <com.example.rects.ui.view.LevelCardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:onClick="onClickSelectImpossible"
                app:levelAccent="@color/level_terracotta"
                app:levelDanger="true"
                app:levelSubtitle="@string/impossible_level_description"
                app:levelTitle="@string/impossible_level" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
