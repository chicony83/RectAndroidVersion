<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/pause_menu_panel"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/pauseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="@string/pause_title"
            android:textColor="@color/menu_text_primary"
            android:textSize="30sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/themeSwitcher"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:contentDescription="@string/light_theme"
                android:gravity="center"
                android:text="☀"
                android:textColor="@color/level_sand"
                android:textSize="21sp" />

            <Switch
                android:id="@+id/themeSwitch"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:checked="true"
                android:clickable="false"
                android:focusable="false"
                android:showText="false"
                android:splitTrack="false"
                android:thumb="@drawable/pause_switch_thumb"
                android:track="@drawable/pause_switch_track" />

            <TextView
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:contentDescription="@string/dark_theme"
                android:gravity="center"
                android:text="☾"
                android:textColor="@color/level_blue"
                android:textSize="24sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:text="@string/pause_subtitle"
        android:textColor="@color/menu_text_secondary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/newGameButton"
        style="@style/MenuPrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="32dp"
        android:text="@string/new_game" />

    <Button
        android:id="@+id/saveGameButton"
        style="@style/MenuSecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="12dp"
        android:text="@string/save_game" />

    <Button
        android:id="@+id/mainMenuButton"
        style="@style/MenuSecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="12dp"
        android:text="@string/main_menu" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="@string/back_to_continue"
        android:textColor="@color/menu_text_muted"
        android:textSize="12sp" />

</LinearLayout>
